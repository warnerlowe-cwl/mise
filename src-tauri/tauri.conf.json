{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mise",
  "version": "0.2.25",
  "identifier": "com.crownwelllabs.mise",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mise \u2014 Food Cost Management",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Food cost management for professional kitchens",
    "longDescription": "Mise is a professional food cost management desktop application. Build and cost recipes from an ingredient library, track waste and spoilage, and get clear reports on where your food cost is going. Offline-first, one-time purchase.",
    "copyright": "Copyright \u00a9 2026 CrownWell Labs",
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "mise"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0Qzg3NEMxODUyQTY4OEQKUldTTmFDcUZ3WFRJSkZmTTU4Q28zRFJiM3MrQ3FydXpzNVBaVENkLy9WU0ZDZ0gyNzNBMkZNSlQK",
      "endpoints": [
        "https://downloads.crownwelllabs.com/mise/latest.json"
      ]
    }
  }
}